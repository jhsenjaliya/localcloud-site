---
/**
 * Callout / admonition component — Mintlify-style.
 *
 * Usage in MDX:
 *   <Callout type="info">This is informational.</Callout>
 *   <Callout type="warning">Watch out!</Callout>
 *   <Callout type="tip">Pro tip here.</Callout>
 *   <Callout type="error">Something broke.</Callout>
 */
interface Props {
  type?: 'info' | 'warning' | 'tip' | 'error';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const icons: Record<string, string> = {
  info: '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  warning: '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>',
  tip: '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>',
  error: '<circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>',
};

const defaultTitles: Record<string, string> = {
  info: 'Info',
  warning: 'Warning',
  tip: 'Tip',
  error: 'Danger',
};
---

<aside class:list={['callout', `callout--${type}`]} role="note" aria-label={title ?? defaultTitles[type]}>
  <div class="callout__icon">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <Fragment set:html={icons[type]} />
    </svg>
  </div>
  <div class="callout__body">
    {(title || defaultTitles[type]) && (
      <p class="callout__title">{title ?? defaultTitles[type]}</p>
    )}
    <div class="callout__content">
      <slot />
    </div>
  </div>
</aside>
