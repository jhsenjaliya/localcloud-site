---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Search documentation" hidden>
  <div class="search-modal__backdrop"></div>
  <div class="search-modal__container">
    <div class="search-modal__header">
      <div class="search-modal__input-wrap">
        <svg class="search-modal__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          id="search-input"
          class="search-modal__input"
          type="search"
          placeholder="Search documentation..."
          autocomplete="off"
          autofocus
        />
        <kbd class="search-modal__kbd">Esc</kbd>
      </div>
    </div>
    <div id="search-results" class="search-modal__results">
      <div class="search-modal__empty">
        <p>Type to search across all documentation pages</p>
        <p class="search-modal__hint">Try: "bigquery", "configuration", "seed data"</p>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var modal = document.getElementById('search-modal');
  var input = document.getElementById('search-input');
  var results = document.getElementById('search-results');
  var backdrop = modal?.querySelector('.search-modal__backdrop');
  var pagefind = null;
  var debounceTimer = null;

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
      return pagefind;
    } catch (e) {
      return null;
    }
  }

  function openSearch() {
    if (!modal) return;
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    setTimeout(function() { input?.focus(); }, 50);
    if (typeof posthog !== 'undefined') {
      posthog.capture('search_opened', { page_path: window.location.pathname });
    }
  }

  function closeSearch() {
    if (!modal) return;
    modal.hidden = true;
    document.body.style.overflow = '';
    if (input) input.value = '';
    if (results) {
      results.innerHTML = '<div class="search-modal__empty"><p>Type to search across all documentation pages</p><p class="search-modal__hint">Try: "bigquery", "configuration", "seed data"</p></div>';
    }
  }

  // Keyboard shortcuts
  document.addEventListener('keydown', function(e) {
    // Cmd+K or Ctrl+K to open
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal?.hidden) {
        openSearch();
      } else {
        closeSearch();
      }
    }
    // Escape to close
    if (e.key === 'Escape' && !modal?.hidden) {
      closeSearch();
    }
  });

  // Backdrop click to close
  backdrop?.addEventListener('click', closeSearch);

  // Search trigger buttons
  document.addEventListener('click', function(e) {
    if (e.target.closest('[data-search-trigger]')) {
      e.preventDefault();
      openSearch();
    }
  });

  // Search input handler
  input?.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    var query = input.value.trim();

    if (!query) {
      results.innerHTML = '<div class="search-modal__empty"><p>Type to search across all documentation pages</p><p class="search-modal__hint">Try: "bigquery", "configuration", "seed data"</p></div>';
      return;
    }

    debounceTimer = setTimeout(async function() {
      var pf = await loadPagefind();
      if (!pf) {
        results.innerHTML = '<div class="search-modal__empty"><p>Search index not available. Run <code>npm run build</code> first.</p></div>';
        return;
      }

      var search = await pf.search(query);
      if (!search.results.length) {
        results.innerHTML = '<div class="search-modal__empty"><p>No results for "<strong>' + query.replace(/</g, '&lt;') + '</strong>"</p></div>';
        return;
      }

      var html = '<ul class="search-modal__list">';
      var items = search.results.slice(0, 8);
      for (var i = 0; i < items.length; i++) {
        var data = await items[i].data();
        html += '<li><a href="' + data.url + '" class="search-modal__result">';
        html += '<span class="search-modal__result-title">' + (data.meta?.title || data.url) + '</span>';
        html += '<span class="search-modal__result-excerpt">' + (data.excerpt || '') + '</span>';
        html += '</a></li>';
      }
      html += '</ul>';
      results.innerHTML = html;

      // Track search — only for meaningful queries (3+ chars)
      if (query.length >= 3 && typeof posthog !== 'undefined') {
        posthog.capture('docs_search', {
          query: query,
          results_count: search.results.length,
          page_path: window.location.pathname,
        });
      }
    }, 200);
  });

  // Close on result click
  results?.addEventListener('click', function(e) {
    if (e.target.closest('.search-modal__result')) {
      closeSearch();
    }
  });

  // Expose globally for header button
  window.__lcSearch = { open: openSearch, close: closeSearch };
})();
</script>
