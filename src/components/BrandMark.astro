---
interface Props {
  size?: number;
  alt?: string;
  class?: string;
}

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const { size = 42, alt = '', class: className = '' } = Astro.props;
const decorative = alt.length === 0;
---

<img
  src={`${base}brand/localcloud-mark.svg`}
  alt={alt}
  aria-hidden={decorative ? 'true' : undefined}
  class:list={['brand-mark', className]}
  width={size}
  height={size}
/>
