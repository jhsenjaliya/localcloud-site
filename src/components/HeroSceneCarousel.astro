---

<div class="hero-carousel reveal">
  <div class="hero-carousel__slides">
    {scenes.map((scene, index) => (
      <div class:list={['hero-carousel__slide', index === 0 && 'is-active']} data-slide={index}>
        <div class="hero-carousel__art" set:html={scene.markup}></div>
      </div>
    ))}
  </div>

  <div class="hero-carousel__footer">
    <div class="hero-carousel__meta">
      {scenes.map((scene, index) => (
        <div class:list={['hero-carousel__copy', index === 0 && 'is-active']} data-copy={index}>
          <div class="site-kicker">{scene.title}</div>
          <p>{scene.caption}</p>
        </div>
      ))}
    </div>

    <div class="hero-carousel__controls" role="tablist" aria-label="Hero scene choices">
      {scenes.map((scene, index) => (
        <button
          class:list={['hero-carousel__dot', index === 0 && 'is-active']}
          type="button"
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-label={`Show ${scene.title}`}
          data-target={index}
        ></button>
      ))}
    </div>
  </div>
</div>

<style>
  .hero-carousel {
    border: 1px solid var(--line);
    border-radius: 1.6rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 255, 0.98));
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .hero-carousel__slides {
    position: relative;
    min-height: 25rem;
  }

  .hero-carousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transform: translateX(1.5rem);
    transition: opacity 320ms ease, transform 320ms ease;
  }

  .hero-carousel__slide.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  .hero-carousel__art {
    height: 100%;
  }

  .hero-carousel__art :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-carousel__footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem 1.1rem;
    border-top: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.82);
  }

  .hero-carousel__meta {
    min-height: 3.7rem;
    position: relative;
    flex: 1 1 auto;
  }

  .hero-carousel__copy {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(0.4rem);
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .hero-carousel__copy.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-carousel__copy p {
    margin-top: 0.45rem;
    color: var(--text-2);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .hero-carousel__controls {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex: 0 0 auto;
  }

  .hero-carousel__dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(44, 114, 246, 0.22);
    background: rgba(44, 114, 246, 0.14);
    cursor: pointer;
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .hero-carousel__dot.is-active {
    background: var(--accent);
    border-color: var(--accent);
    transform: scale(1.12);
  }

  @media (max-width: 640px) {
    .hero-carousel__slides {
      min-height: 21rem;
    }

    .hero-carousel__footer {
      flex-direction: column;
      align-items: start;
    }
  }
</style>

<script>
  const carousels = document.querySelectorAll('.hero-carousel');

  carousels.forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll('[data-slide]'));
    const copies = Array.from(carousel.querySelectorAll('[data-copy]'));
    const dots = Array.from(carousel.querySelectorAll('[data-target]'));
    let current = 0;
    let timer;

    const setActive = (index) => {
      current = index;
      slides.forEach((slide, slideIndex) => slide.classList.toggle('is-active', slideIndex === index));
      copies.forEach((copy, copyIndex) => copy.classList.toggle('is-active', copyIndex === index));
      dots.forEach((dot, dotIndex) => {
        const active = dotIndex === index;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-selected', String(active));
      });
    };

    const start = () => {
      timer = window.setInterval(() => {
        setActive((current + 1) % slides.length);
      }, 5200);
    };

    const restart = () => {
      window.clearInterval(timer);
      start();
    };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        setActive(index);
        restart();
      });
    });

    carousel.addEventListener('mouseenter', () => window.clearInterval(timer));
    carousel.addEventListener('mouseleave', start);

    setActive(0);
    start();
  });
</script>
