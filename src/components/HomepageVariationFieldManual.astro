---
import CopyButton from './CopyButton.astro';
import ServiceIcon from './ServiceIcon.astro';
import { serviceCategoryMeta, serviceCategoryOrder, services } from '../data/services';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const categoryTones = ['sky', 'sage', 'ember'] as const;

const dockerCmd = `docker pull jaysen2apache/localcloud

docker run -d \\
  -p 8080:8080 -p 4443:4443 \\
  -p 8085-8087:8085-8087 \\
  -p 9010:9010 -p 9050:9050 -p 6379:6379 \\
  -m 4g --name localcloud \\
  jaysen2apache/localcloud

eval "$(curl -s localhost:8080/_localcloud/env?format=shell)"`;

const heroSignals = [
  { value: 'Major', label: 'Google Cloud services', note: 'storage, data, events, ops, and runtime' },
  { value: '1', label: 'Docker container', note: 'one local boot path for the team' },
  { value: '$0', label: 'cloud spend during iteration', note: 'stay local until the team is ready' },
];

const heroOrbit = [
  { slug: 'cloud-storage', left: '10%', top: '10%', delay: '0s' },
  { slug: 'pubsub', left: '49%', top: '4%', delay: '0.8s' },
  { slug: 'firestore', left: '79%', top: '12%', delay: '1.5s' },
  { slug: 'bigquery', left: '84%', top: '46%', delay: '2.1s' },
  { slug: 'spanner', left: '70%', top: '74%', delay: '1.1s' },
  { slug: 'cloud-tasks', left: '26%', top: '78%', delay: '2.7s' },
  { slug: 'secret-manager', left: '6%', top: '52%', delay: '1.8s' },
  { slug: 'cloud-workflows', left: '52%', top: '86%', delay: '0.4s' },
].map((entry) => ({
  ...entry,
  service: services.find((service) => service.slug === entry.slug)!,
}));

const storyCards = [
  {
    eyebrow: 'Zero code changes',
    title: 'Keep your existing SDK flow and point it at localhost.',
    body: 'LocalCloud is at its best when the setup stays boring: boot the container, export the environment variables, and keep using the same Google Cloud client libraries.',
  },
  {
    eyebrow: 'Visible local runtime',
    title: 'Open the console, inspect service health, and verify the stack before you debug your app.',
    body: 'The best developer tools remove guessing. LocalCloud gives you the env handoff, health surface, seeded sample data, and a browser console right after boot.',
  },
  {
    eyebrow: 'Fast inner loop',
    title: 'Keep early development local before you spend time and money in shared cloud projects.',
    body: 'Storage, databases, messaging, operations, and runtime surfaces are all easy to browse from one place, so teams can move quickly without losing visibility.',
  },
];

const atlasColumns = serviceCategoryOrder
  .map((category, index) => ({
    category,
    title: serviceCategoryMeta[category].label,
    note: serviceCategoryMeta[category].description,
    tone: categoryTones[index % categoryTones.length],
    items: services.filter((service) => service.category === category),
  }))
  .filter((column) => column.items.length > 0);
---

<main id="main-content" class="field-home">
  <div class="field-home__shell">
    <section class="field-hero">
      <div class="field-hero__copy">
        <div class="field-hero__meta">
          <span class="field-stamp">Most Google Cloud services</span>
        </div>

        <span class="field-ledger">Single-container local runtime</span>

        <p class="field-overline">No cloud access. No credentials. No cloud costs.</p>
        <h1>Google Cloud In-a-Box.</h1>
        <p class="field-intro">
          LocalCloud brings the major Google Cloud services teams reach for first into one Docker container, exports localhost targets for the SDKs,
          and gives you a console to inspect the runtime before you ever touch a shared project.
        </p>

        <div class="field-actions">
          <a href="#manual-quickstart" class="field-button field-button--primary">Open the Quick Start</a>
          <a href={`${base}docs/`} class="field-button field-button--secondary">Read the Setup Guide</a>
        </div>

        <ul class="field-signal-strip">
          {heroSignals.map((signal) => (
            <li class="field-signal">
              <div class="field-signal__value">{signal.value}</div>
              <div class="field-signal__meta">
                <div class="field-signal__label">{signal.label}</div>
                <div class="field-signal__note">{signal.note}</div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="field-board">
        <div class="field-board__title">
          <span class="field-kicker">Local Runtime View</span>
          <p>A visible local stack for storage, databases, analytics, messaging, operations, and compute-oriented workflows.</p>
        </div>

        <div class="field-board__surface">
          <div class="field-board__rings"></div>

          {heroOrbit.map((item) => (
            <article class="field-orbit" style={`left:${item.left};top:${item.top};animation-delay:${item.delay};`}>
              <span class="field-orbit__icon">
                <ServiceIcon iconId={item.service.iconId} name={item.service.name} size={26} />
              </span>
            </article>
          ))}

          <div class="field-board__cube">
            <div class="field-board__cube-shell">
              <div class="field-board__cylinders">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="field-board__routes">
                <i></i>
                <i></i>
                <i></i>
              </div>
            </div>
            <div class="field-board__tag">Major services / 1 container</div>
          </div>

          <div class="field-board__cable"></div>

          <div class="field-board__laptop">
            <div class="field-board__screen">
              <div class="field-board__screen-top">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="field-board__status-list">
                <div><b></b> gateway healthy</div>
                <div><b></b> env handoff ready</div>
                <div><b></b> services online</div>
              </div>
            </div>
            <div class="field-board__base"></div>
          </div>

          <div class="field-board__note field-board__note--left">
            <span class="field-kicker">Assembly</span>
            <strong>Single launch path</strong>
            <p>Pull one image, start one container, export the localhost endpoints, and keep coding.</p>
          </div>

          <div class="field-board__note field-board__note--right">
            <span class="field-kicker">Coverage</span>
            <strong>{atlasColumns.length} product categories in one local runtime</strong>
            <p>Storage, data, events, operations, and runtime surfaces are grouped the way Google Cloud teams already think about them.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="field-quickstart" id="manual-quickstart">
      <article class="field-card field-card--paper">
        <span class="field-kicker">Quick Start</span>
        <h2>Boot LocalCloud in less than 1 minute.</h2>
        <p>
          Pull the image, start the container, export the generated environment variables, and point your existing Google Cloud SDK clients at localhost.
        </p>

        <ol class="field-steps">
          <li><span>01</span> Pull the image and boot the default runtime footprint.</li>
          <li><span>02</span> Export the generated localhost endpoints for the SDKs.</li>
          <li><span>03</span> Open the console, verify service health, and make your first API call.</li>
        </ol>
      </article>

      <article class="field-card field-card--terminal">
        <div class="field-terminal__head">
          <div>
            <span class="field-kicker">Command Deck</span>
            <p>One copyable path for the default runtime.</p>
          </div>
          <CopyButton text={dockerCmd} class="field-copy" />
        </div>

        <pre><code>{dockerCmd}</code></pre>
      </article>
    </section>

    <section class="field-ribbon">
      <article class="field-ribbon__item">
        <span class="field-kicker">Zero Code Changes</span>
        <strong>Use the same Google Cloud SDKs and retarget them with one exported env block.</strong>
      </article>
      <article class="field-ribbon__item">
        <span class="field-kicker">Operational Handoff</span>
        <strong>Console, health, env export, and seeded sample data make the runtime inspectable immediately.</strong>
      </article>
      <article class="field-ribbon__item">
        <span class="field-kicker">Inner Loop Speed</span>
        <strong>Stay local while you shape the app, then switch back to shared Google Cloud environments when you are ready.</strong>
      </article>
    </section>

    <section class="field-atlas">
      <div class="field-section-heading">
        <span class="field-kicker">Service Atlas</span>
        <h2>Browse LocalCloud by product category, not emulator internals.</h2>
        <p>Storage, databases, analytics, messaging, security, operations, and compute are grouped the same way platform teams already scan Google Cloud.</p>
      </div>

      <div class="field-atlas__grid">
        {atlasColumns.map((column) => (
          <article class:list={['field-column', `field-column--${column.tone}`]}>
            <div class="field-column__head">
              <span class="field-kicker">{column.title}</span>
              <p>{column.note}</p>
            </div>

            <div class="field-column__list">
              {column.items.map((service) => (
                <div class="field-service">
                  <div class="field-service__main">
                    <span class="field-service__icon">
                      <ServiceIcon iconId={service.iconId} name={service.name} size={24} />
                    </span>
                    <div>
                      <strong>{service.name}</strong>
                      <p>{service.description}</p>
                    </div>
                  </div>

                  <div class="field-service__tags">
                    <span>{service.enabled ? 'Default-on' : 'Opt-in'}</span>
                    <span>{service.protocol}</span>
                    <span>:{service.port}</span>
                  </div>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="field-story">
      {storyCards.map((card) => (
        <article class="field-story__card">
          <span class="field-kicker">{card.eyebrow}</span>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </section>

    <section class="field-cta">
      <div>
        <span class="field-kicker">Continue Exploring</span>
        <h2>Boot LocalCloud in less than 1 minute, then dig into the docs or the full service atlas.</h2>
        <p>
          The homepage tells you what LocalCloud is. The docs and service pages explain how to use it, what each service supports, and where the runtime boundaries are.
        </p>
      </div>

      <div class="field-cta__actions">
        <a href={`${base}docs/`} class="field-button field-button--secondary">Open Documentation</a>
        <a href={`${base}services/`} class="field-button field-button--primary">Open Service Catalog</a>
      </div>
    </section>
  </div>
</main>

<style>
  .field-home {
    --field-bg: #edf4ff;
    --field-paper: #f8fbff;
    --field-paper-2: #eef4ff;
    --field-panel: #fbfdff;
    --field-ink: #13233d;
    --field-muted: #5c6f89;
    --field-line: rgba(102, 128, 173, 0.18);
    --field-line-strong: rgba(102, 128, 173, 0.3);
    --field-accent: #2d6cdf;
    --field-accent-strong: #1d56ba;
    --field-accent-soft: rgba(45, 108, 223, 0.12);
    --field-moss: #147d72;
    --field-moss-soft: rgba(20, 125, 114, 0.12);
    --field-sky: #315f8f;
    --field-sky-soft: rgba(49, 95, 143, 0.12);
    --field-deep: #18263b;
    --field-shadow: 0 24px 60px -32px rgba(48, 73, 122, 0.24);
    --font-border: rgba(112, 136, 176, 0.35);
    --border: rgba(188, 210, 242, 0.82);
    --border-hover: rgba(45, 108, 223, 0.5);
    --text: var(--field-ink);
    --text-3: var(--field-muted);
    padding: 1.5rem 0 3rem;
    color: var(--field-ink);
  }

  .field-home__shell {
    width: min(100% - 1.5rem, 79rem);
    margin: 0 auto;
    padding: 1rem;
    border: 1px solid var(--field-line-strong);
    border-radius: 2rem;
    background:
      linear-gradient(180deg, rgba(251, 253, 255, 0.96), rgba(237, 244, 255, 0.94)),
      linear-gradient(90deg, rgba(45, 108, 223, 0.04), rgba(20, 125, 114, 0.03));
    box-shadow: var(--field-shadow);
    position: relative;
    overflow: hidden;
  }

  .field-home__shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(96, 122, 165, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(96, 122, 165, 0.045) 1px, transparent 1px);
    background-size: 2rem 2rem;
    pointer-events: none;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.7), transparent 92%);
  }

  .field-hero,
  .field-quickstart,
  .field-ribbon,
  .field-atlas,
  .field-story,
  .field-cta {
    position: relative;
    z-index: 1;
  }

  .field-hero {
    display: grid;
    gap: 2rem;
    padding: 1rem 0 1rem;
  }

  .field-hero__meta,
  .field-actions,
  .field-signal-strip,
  .field-board__title,
  .field-quickstart,
  .field-ribbon,
  .field-atlas__grid,
  .field-story,
  .field-cta {
    display: grid;
    gap: 1rem;
  }

  .field-stamp,
  .field-ledger,
  .field-kicker,
  .field-overline,
  .field-signal__label {
    font-family: var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .field-stamp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 0.55rem 0.9rem;
    border: 1px solid rgba(45, 108, 223, 0.35);
    border-radius: 999px;
    background: rgba(45, 108, 223, 0.08);
    color: var(--field-accent-strong);
    font-size: 0.72rem;
  }

  .field-ledger,
  .field-kicker,
  .field-signal__label,
  .field-overline {
    color: var(--field-muted);
    font-size: 0.72rem;
  }

  .field-overline {
    margin-top: 1rem;
  }

  .field-hero h1,
  .field-section-heading h2,
  .field-quickstart h2,
  .field-cta h2 {
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    letter-spacing: -0.045em;
    line-height: 0.95;
    color: var(--field-ink);
  }

  .field-hero h1 {
    margin-top: 1rem;
    max-width: 11ch;
    font-size: clamp(3.4rem, 8vw, 6.25rem);
  }

  .field-intro,
  .field-board__title p,
  .field-card p,
  .field-section-heading p,
  .field-column__head p,
  .field-story__card p,
  .field-cta p {
    color: var(--field-muted);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .field-actions {
    grid-template-columns: repeat(2, max-content);
    margin-top: 1.5rem;
  }

  .field-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0 1.2rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 0.96rem;
    font-weight: 600;
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .field-button:hover {
    transform: translateY(-1px);
  }

  .field-button--primary {
    background: linear-gradient(135deg, var(--field-accent-strong), var(--field-accent));
    color: #f5f9ff;
    box-shadow: 0 14px 24px -18px rgba(29, 86, 186, 0.72);
  }

  .field-button--secondary {
    border-color: var(--field-line-strong);
    background: rgba(251, 253, 255, 0.9);
    color: var(--field-ink);
  }

  .field-signal-strip {
    margin-top: 1.5rem;
    padding: 0;
    list-style: none;
  }

  .field-signal {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: start;
    padding: 1rem;
    border: 1px solid var(--field-line);
    border-radius: 1.1rem;
    background: rgba(251, 253, 255, 0.8);
  }

  .field-signal__value {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    color: var(--field-ink);
  }

  .field-signal__note {
    margin-top: 0.15rem;
    color: var(--field-muted);
    font-size: 0.9rem;
  }

  .field-board {
    display: grid;
    gap: 1rem;
    padding: 1.2rem;
    border: 1px solid var(--field-line);
    border-radius: 1.75rem;
    background: linear-gradient(180deg, rgba(248, 251, 255, 0.96), rgba(235, 243, 255, 0.94));
  }

  .field-board__surface {
    position: relative;
    min-height: 34rem;
    overflow: hidden;
    border: 1px solid rgba(120, 98, 69, 0.16);
    border-radius: 1.4rem;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.45), transparent 35%),
      linear-gradient(180deg, rgba(34, 42, 53, 0.95), rgba(27, 31, 39, 0.98));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .field-board__rings {
    position: absolute;
    inset: 10% 11%;
    border: 1px solid rgba(122, 163, 251, 0.14);
    border-radius: 50%;
  }

  .field-board__rings::before,
  .field-board__rings::after {
    content: "";
    position: absolute;
    inset: 15%;
    border-radius: 50%;
    border: 1px dashed rgba(122, 163, 251, 0.16);
  }

  .field-board__rings::after {
    inset: 31%;
    border-style: solid;
    border-color: rgba(76, 210, 168, 0.12);
  }

  .field-orbit {
    position: absolute;
    width: 3.4rem;
    height: 3.4rem;
    display: grid;
    place-items: center;
    border: 1px solid rgba(122, 163, 251, 0.2);
    border-radius: 1rem;
    background: rgba(248, 252, 255, 0.96);
    box-shadow: 0 10px 30px -16px rgba(19, 28, 39, 0.8);
    animation: field-float 6.8s ease-in-out infinite;
  }

  .field-orbit__icon {
    display: grid;
    place-items: center;
  }

  .field-board__cube {
    position: absolute;
    left: 27%;
    top: 25%;
    width: 15rem;
    display: grid;
    justify-items: center;
    gap: 0.9rem;
  }

  .field-board__cube-shell {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 1.5rem;
    border: 1px solid rgba(122, 163, 251, 0.46);
    background:
      linear-gradient(135deg, rgba(102, 183, 255, 0.18), rgba(47, 108, 99, 0.08)),
      linear-gradient(180deg, rgba(238, 247, 255, 0.16), rgba(11, 14, 21, 0.12));
    box-shadow:
      inset 0 0 0 1px rgba(225, 243, 255, 0.14),
      0 0 50px -24px rgba(73, 138, 232, 0.75);
    backdrop-filter: blur(10px);
    display: grid;
    place-items: center;
    position: relative;
  }

  .field-board__cube-shell::before,
  .field-board__cube-shell::after {
    content: "";
    position: absolute;
    border-radius: 1.15rem;
    border: 1px solid rgba(144, 197, 255, 0.22);
  }

  .field-board__cube-shell::before {
    inset: 1rem;
  }

  .field-board__cube-shell::after {
    inset: 2rem;
  }

  .field-board__cylinders {
    display: flex;
    gap: 0.85rem;
    align-items: end;
  }

  .field-board__cylinders span {
    width: 1.9rem;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(165, 214, 255, 0.95), rgba(65, 120, 200, 0.42));
    box-shadow: 0 0 18px -8px rgba(108, 180, 255, 0.9);
  }

  .field-board__cylinders span:nth-child(1) {
    height: 4.9rem;
  }

  .field-board__cylinders span:nth-child(2) {
    height: 6.4rem;
  }

  .field-board__cylinders span:nth-child(3) {
    height: 4.1rem;
  }

  .field-board__routes {
    position: absolute;
    inset: auto 1.5rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .field-board__routes i {
    display: block;
    height: 0.32rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(97, 216, 160, 0.14), rgba(97, 216, 160, 0.88), rgba(97, 216, 160, 0.14));
    animation: field-pulse 2.6s ease-in-out infinite;
  }

  .field-board__routes i:nth-child(2) {
    animation-delay: 0.6s;
  }

  .field-board__routes i:nth-child(3) {
    animation-delay: 1.2s;
  }

  .field-board__tag {
    padding: 0.45rem 0.75rem;
    border: 1px solid rgba(222, 232, 255, 0.22);
    border-radius: 999px;
    background: rgba(243, 249, 255, 0.08);
    color: #deedff;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .field-board__cable {
    position: absolute;
    left: 52%;
    top: 57%;
    width: 18%;
    height: 0.45rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(122, 163, 251, 0.1), rgba(122, 163, 251, 0.95), rgba(97, 216, 160, 0.35));
    transform: rotate(8deg);
    box-shadow: 0 0 20px -8px rgba(97, 216, 160, 0.8);
  }

  .field-board__laptop {
    position: absolute;
    right: 7%;
    bottom: 14%;
    width: 31%;
  }

  .field-board__screen {
    border: 1px solid rgba(214, 228, 247, 0.26);
    border-radius: 1rem 1rem 0.55rem 0.55rem;
    background: #0e1621;
    padding: 0.85rem;
    box-shadow: 0 20px 35px -28px rgba(9, 14, 24, 0.9);
  }

  .field-board__screen-top {
    display: flex;
    gap: 0.45rem;
    margin-bottom: 0.8rem;
  }

  .field-board__screen-top span {
    width: 0.52rem;
    height: 0.52rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.28);
  }

  .field-board__screen-top span:nth-child(3) {
    background: rgba(97, 216, 160, 0.9);
    box-shadow: 0 0 12px -2px rgba(97, 216, 160, 0.85);
  }

  .field-board__status-list {
    display: grid;
    gap: 0.55rem;
    color: #d3e3ff;
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .field-board__status-list div {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .field-board__status-list b {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #61d8a0;
    box-shadow: 0 0 12px -2px rgba(97, 216, 160, 0.82);
  }

  .field-board__base {
    width: 113%;
    height: 0.8rem;
    margin: -0.05rem auto 0;
    border-radius: 0 0 1.2rem 1.2rem;
    background: linear-gradient(180deg, #dfe6ef, #acb6c5);
  }

  .field-board__note {
    position: absolute;
    width: min(38vw, 13rem);
    padding: 0.9rem;
    border-radius: 1rem;
