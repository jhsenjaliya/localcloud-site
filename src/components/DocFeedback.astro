---
// "Was this page helpful?" widget for doc articles
// Sends feedback to PostHog as events
---

<div class="doc-feedback" data-feedback-widget>
  <div class="doc-feedback__prompt" data-feedback-prompt>
    <span class="doc-feedback__label">Was this page helpful?</span>
    <div class="doc-feedback__buttons">
      <button type="button" class="doc-feedback__btn" data-feedback="yes" aria-label="Yes, this page was helpful">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 10v12"/>
          <path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/>
        </svg>
        Yes
      </button>
      <button type="button" class="doc-feedback__btn" data-feedback="no" aria-label="No, this page was not helpful">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 14V2"/>
          <path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L12 22a3.13 3.13 0 0 1-3-3.88Z"/>
        </svg>
        No
      </button>
    </div>
  </div>

  <div class="doc-feedback__followup" data-feedback-followup hidden>
    <textarea
      class="doc-feedback__textarea"
      data-feedback-comment
      placeholder="What could be improved? (optional)"
      rows="2"
      maxlength="500"
    ></textarea>
    <div class="doc-feedback__followup-actions">
      <button type="button" class="doc-feedback__submit" data-feedback-submit>Send feedback</button>
      <button type="button" class="doc-feedback__skip" data-feedback-skip>Skip</button>
    </div>
  </div>

  <div class="doc-feedback__thanks" data-feedback-thanks hidden>
    <span>Thanks for your feedback!</span>
  </div>
</div>

<script is:inline>
(function() {
  document.querySelectorAll('[data-feedback-widget]').forEach(function(widget) {
    var prompt = widget.querySelector('[data-feedback-prompt]');
    var followup = widget.querySelector('[data-feedback-followup]');
    var thanks = widget.querySelector('[data-feedback-thanks]');
    var comment = widget.querySelector('[data-feedback-comment]');
    var helpful = null;

    function sendFeedback(extra) {
      if (typeof posthog === 'undefined') return;
      var props = {
        helpful: helpful,
        page_path: window.location.pathname,
        page_title: document.title,
      };
      if (extra) props.comment = extra;
      posthog.capture('doc_feedback', props);
    }

    function showThanks() {
      if (followup) followup.hidden = true;
      if (prompt) prompt.hidden = true;
      if (thanks) thanks.hidden = false;
    }

    widget.querySelectorAll('[data-feedback]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        helpful = btn.getAttribute('data-feedback') === 'yes';
        if (helpful) {
          sendFeedback();
          showThanks();
        } else {
          if (prompt) prompt.hidden = true;
          if (followup) followup.hidden = false;
          comment?.focus();
        }
      });
    });

    var submitBtn = widget.querySelector('[data-feedback-submit]');
    submitBtn?.addEventListener('click', function() {
      sendFeedback((comment?.value || '').trim());
      showThanks();
    });

    var skipBtn = widget.querySelector('[data-feedback-skip]');
    skipBtn?.addEventListener('click', function() {
      sendFeedback();
      showThanks();
    });
  });
})();
</script>
