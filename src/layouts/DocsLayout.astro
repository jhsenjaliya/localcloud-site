---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title?: string;
    description?: string;
  };
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? frontmatter.title ?? 'Documentation';
const description = Astro.props.description ?? frontmatter.description;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const currentPath = Astro.url.pathname;

const sidebarSections = [
  { title: 'Getting Started', items: [{ label: 'Introduction', href: `${base}docs/` }] },
  { title: 'Services', items: [{ label: 'Overview', href: `${base}docs/services-overview/` }] },
  { title: 'Reference', items: [
    { label: 'Configuration', href: `${base}docs/configuration/` },
    { label: 'Seed Data', href: `${base}docs/seed-data/` },
    { label: 'SDK Examples', href: `${base}docs/sdk-examples/` },
  ]},
  { title: 'Learn', items: [
    { label: 'Architecture', href: `${base}docs/architecture/` },
    { label: 'BigQuery locally', href: `${base}docs/bigquery-locally/` },
    { label: 'Web Console', href: `${base}docs/console/` },
    { label: 'FAQ', href: `${base}docs/faq/` },
  ]},
];

const normalizePath = (path: string) => (path.endsWith('/') ? path : `${path}/`);
const allLinks = sidebarSections.flatMap((section) =>
  section.items.map((item) => ({
    ...item,
    sectionTitle: section.title,
  }))
);
const normalizedCurrentPath = normalizePath(currentPath);
const currentIndex = allLinks.findIndex((item) => normalizePath(item.href) === normalizedCurrentPath);
const currentItem = currentIndex >= 0 ? allLinks[currentIndex] : undefined;
const previousItem = currentIndex > 0 ? allLinks[currentIndex - 1] : undefined;
const nextItem = currentIndex >= 0 && currentIndex < allLinks.length - 1 ? allLinks[currentIndex + 1] : undefined;
const tocItems = (Astro.props.headings ?? []).filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<BaseLayout title={`${title} — LocalCloud Docs`} description={description}>
  <Header />

  <main id="main-content" class="site-page docs-page">
    <section class="site-section site-section--tight">
      <div class="container">
        <div class="docs-toolbar reveal">
          <div class="docs-toolbar__crumbs">
            <a href={`${base}docs/`}>Documentation</a>
            {currentItem && (
              <>
                <span>/</span>
                <span>{currentItem.sectionTitle}</span>
              </>
            )}
          </div>

          <div class="docs-toolbar__actions">
            <a href={`${base}services/`}>Service Catalog</a>
            <a href="https://github.com/LocalStack-Google/localstack-google.github.io" target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </div>

        <div class="docs-mobile-nav">
          {allLinks.map((item) => (
            <a
              href={item.href}
              class:list={[
                'site-nav__link',
                normalizePath(item.href) === normalizedCurrentPath && 'is-active',
              ]}
            >
              {item.label}
            </a>
          ))}
        </div>

        <div class:list={['docs-shell', tocItems.length > 0 && 'docs-shell--with-toc']}>
          <aside class="site-panel docs-sidebar">
            <div class="docs-sidebar__intro">
              <span class="site-kicker">Documentation</span>
            </div>

            {sidebarSections.map((section) => (
              <div class="docs-sidebar__section">
                <h4>{section.title}</h4>
                <ul class="docs-sidebar__links">
                  {section.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          'docs-sidebar__link',
                          normalizePath(item.href) === normalizedCurrentPath && 'is-active',
                        ]}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </aside>

          <article class="site-panel docs-article">
            <div class="docs-article__frame">
              <div class="docs-article__header">
                <div class="docs-article__context">
                  <span class="site-kicker">{currentItem?.sectionTitle ?? 'Documentation'}</span>
                  {currentItem && <span class="docs-article__current">{currentItem.label}</span>}
                </div>
              </div>

              <div class="prose-site">
                <slot />
              </div>

              {(previousItem || nextItem) && (
                <nav class="docs-pagination" aria-label="Document navigation">
                  {previousItem ? (
                    <a href={previousItem.href} class="docs-pagination__link docs-pagination__link--previous">
                      <span class="docs-pagination__eyebrow">Previous</span>
                      <span class="docs-pagination__title">{previousItem.label}</span>
                    </a>
                  ) : (
                    <span></span>
                  )}

                  {nextItem && (
                    <a href={nextItem.href} class="docs-pagination__link docs-pagination__link--next">
                      <span class="docs-pagination__eyebrow">Next</span>
                      <span class="docs-pagination__title">{nextItem.label}</span>
                    </a>
                  )}
                </nav>
              )}
            </div>
          </article>

          {tocItems.length > 0 && (
            <aside class="site-panel docs-toc">
              <div class="docs-toc__inner">
                <span class="site-kicker">On This Page</span>
                <ul class="docs-toc__list">
                  {tocItems.map((item) => (
                    <li class:list={['docs-toc__item', item.depth === 3 && 'is-nested']}>
                      <a href={`#${item.slug}`} class="docs-toc__link">
                        {item.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </aside>
          )}
        </div>
      </div>
    </section>
  </main>

  <script>
    const enhanceDocsCodeBlocks = () => {
      document.querySelectorAll('.docs-article pre').forEach((pre) => {
        if (pre.dataset.copyReady === 'true') return;

        const code = pre.querySelector('code');
        const text = code?.textContent?.trimEnd() ?? pre.textContent?.trimEnd();
        if (!text) return;

        pre.dataset.copyReady = 'true';

        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'docs-code-copy';
        button.setAttribute('aria-label', 'Copy code to clipboard');
        button.innerHTML = '<span>Copy</span>';

        button.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(text);
            button.classList.add('is-copied');
            button.innerHTML = '<span>Copied</span>';
            window.setTimeout(() => {
              button.classList.remove('is-copied');
              button.innerHTML = '<span>Copy</span>';
            }, 1800);
          } catch {
            button.innerHTML = '<span>Failed</span>';
            window.setTimeout(() => {
              button.innerHTML = '<span>Copy</span>';
            }, 1800);
          }
        });

        pre.appendChild(button);
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', enhanceDocsCodeBlocks, { once: true });
    } else {
      enhanceDocsCodeBlocks();
    }
  </script>

  <Footer />
</BaseLayout>
